#!/bin/env bash

GUARD_CMD=()
guard() {
    local CMD="$1"
    shift

    if ! command -v "$CMD" >/dev/null 2>&1; then
        echo "Warning: '$CMD' not found! Skipping..."
        return 0
    fi

    case "$CMD" in
        gamemoderun)
            export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}/usr/\$LIB/libgamemode.so"
            ;;
    esac

    GUARD_CMD+=("$CMD" "$@")
}

guard gamemoderun
guard prime-run
guard mangohud

"${GUARD_CMD[@]}" "$@"
