#!/bin/sh

guard() {
    local TOOLS="$1"
    shift
    local EXEC_CHAIN=''

    for TOOL in $TOOLS; do
        if command -v "$TOOL" >/dev/null 2>&1; then
            case "$TOOL" in
                "gamemoderun")
                    export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}/usr/\$LIB/libgamemode.so"
                    ;;
            esac

            EXEC_CHAIN="$EXEC_CHAIN $TOOL"
        else
            echo "Warning: '$TOOL' not found! Skipping..."
        fi
    done

    exec $EXEC_CHAIN "$@"
}

guard 'gamemoderun prime-run' "$@"
