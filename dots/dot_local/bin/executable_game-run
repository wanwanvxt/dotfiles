#!/usr/bin/bash

[[ $# -eq 0 ]] && exit 1

cmd=()

has() {
    command -v "$1" &>/dev/null
}

is_gamescope_child() {
    if [[ -n "$GAMESCOPE_WAYLAND_DISPLAY" ]] || [[ "$XDG_CURRENT_DESKTOP" == "gamescope" ]]; then
        return 0
    fi
    return 1
}

has gamemoderun && cmd+=(gamemoderun)
has prime-run   && cmd+=(prime-run)
! is_gamescope_child && has mangohud && cmd+=(mangohud)

cmd+=("$@")

exec "${cmd[@]}"
