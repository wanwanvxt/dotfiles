<?xml version='1.0'?>
<fontconfig>
    <alias binding="same">
        <family>sans-serif</family>
        <prefer>
            {{ range .appearance.fontconfig.sansSerif -}}
            <family>{{ . }}</family>
            {{ end }}
        </prefer>
    </alias>
    <alias binding="same">
        <family>serif</family>
        <prefer>
            {{ range .appearance.fontconfig.serif -}}
            <family>{{ . }}</family>
            {{ end }}
        </prefer>
    </alias>
    <alias binding="same">
        <family>monospace</family>
        <prefer>
            {{ range .appearance.fontconfig.monospace -}}
            <family>{{ . }}</family>
            {{ end }}
        </prefer>
    </alias>
    <alias binding="same">
        <family>emoji</family>
        <prefer>
            {{ range .appearance.fontconfig.emoji -}}
            <family>{{ . }}</family>
            {{ end }}
        </prefer>
    </alias>
</fontconfig>

<!-- vim: ft=xml
-->
